# Get a key at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional but recommended: USDA FoodData Central key for accurate, grounded
# nutrition lookups. Without it the app uses the public DEMO_KEY (~30 req/hour).
# Free signup: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=
